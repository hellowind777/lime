{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/main.tsx"],
  "project": [
    "src/**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "!src/**/*.test.{ts,tsx,js,jsx,mjs,cjs}",
    "!src/**/*.spec.{ts,tsx,js,jsx,mjs,cjs}",
    "!src/**/__tests__/**",
    "!src/**/__mocks__/**",
    "!src/**/*.d.ts"
  ]
}
